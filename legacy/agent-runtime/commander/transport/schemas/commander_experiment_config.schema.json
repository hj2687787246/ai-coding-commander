{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commander Experiment Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "task_id",
    "surface",
    "baseline",
    "candidate",
    "scorecard"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "commander-experiment-v1"
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "enum": [
        "prompt_constitution",
        "routing_context_policy",
        "skill_shell",
        "middleware_wiring",
        "tool_governance_config"
      ]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "changed_files"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "workspace",
        "changed_files"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "min_holdout_delta",
        "train",
        "holdout"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "min_holdout_delta": {
          "type": "number"
        },
        "higher_is_better": {
          "type": "boolean"
        },
        "train": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/case_score"
          }
        },
        "holdout": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/case_score"
          }
        }
      }
    }
  },
  "$defs": {
    "case_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "baseline_score",
        "candidate_score"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "baseline_score": {
          "type": "number"
        },
        "candidate_score": {
          "type": "number"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
