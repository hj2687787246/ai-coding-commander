{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commander Objective Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "objective_id",
    "objective_key",
    "objective_title",
    "objective",
    "status",
    "current_phase_id",
    "current_phase_plan_id",
    "phases",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "objective_id": {
      "type": "string",
      "minLength": 1
    },
    "objective_key": {
      "type": "string",
      "minLength": 1
    },
    "objective_title": {
      "type": "string",
      "minLength": 1
    },
    "objective_theme": {
      "type": [
        "string",
        "null"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "blocked",
        "pending_user",
        "completed",
        "archived"
      ]
    },
    "current_phase_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_phase_plan_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase_id",
          "phase_key",
          "theme_key",
          "phase_title",
          "objective",
          "status",
          "goals"
        ],
        "properties": {
          "phase_id": {
            "type": "string",
            "minLength": 1
          },
          "phase_key": {
            "type": "string",
            "minLength": 1
          },
          "theme_key": {
            "type": "string",
            "minLength": 1
          },
          "phase_title": {
            "type": "string",
            "minLength": 1
          },
          "phase_theme": {
            "type": [
              "string",
              "null"
            ]
          },
          "parallel_dispatch_limit": {
            "type": "integer",
            "minimum": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "active",
              "done",
              "blocked",
              "canceled"
            ]
          },
          "phase_plan_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "goals": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "activated_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_rewritten_at": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
