{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commander Spec Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "spec_id",
    "title",
    "status",
    "owner",
    "constitution",
    "specification",
    "planning",
    "tasking",
    "implementation_state",
    "acceptance",
    "non_goals",
    "invariants",
    "truth_sources",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "retired"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_phase_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_objective_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "constitution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "principles",
        "guardrails"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "principles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guardrails": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "requirements",
        "interfaces",
        "constraints"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "planning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "milestones"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "milestone_id",
              "title",
              "status"
            ],
            "properties": {
              "milestone_id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "planned",
                  "in_progress",
                  "blocked",
                  "done"
                ]
              },
              "goal": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "order": {
                "type": [
                  "integer",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "tasking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "dispatch_rules",
        "task_contracts"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "dispatch_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "task_contracts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "packet_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "implementation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "stage",
        "status",
        "evidence",
        "blockers"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "blocked",
            "done"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "truth_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
